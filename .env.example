# ==== YBRadar 信号源 ====
YBRADAR_API_URL=https://ybradar.qianyuwing.com/api/signals
YBRADAR_SESSION_COOKIE=换成你自己的 ybr_session 值(登录后从浏览器 Cookie 里复制,会过期需要定期更换)
# YBRadar 网站本身也是 3 分钟才扫描更新一次,轮询更快不会让数据更新更快,
# 只会增加对方服务器压力,所以跟数据源更新频率对齐即可
SIGNAL_POLL_INTERVAL_SECONDS=180
# 强信号的 strongSince(信号窗口开始时间)距离现在超过这个秒数就跳过,不进场。
# 没有这个过滤的话,机器人第一次看到一个"已经 active 很久"的信号也会当成新信号进场,
# 等于追一个可能已经走完的行情。要比 SIGNAL_POLL_INTERVAL_SECONDS 明显大一截(留出至少
# 一轮轮询的延迟/漏轮容错空间),不要卡得跟轮询间隔一样紧,否则容易把该抓的新鲜信号
# 悄悄过滤掉(且这种过滤不会打日志)。
MAX_SIGNAL_AGE_SECONDS=300

# 盯仓(检查已开仓位是否触发止盈/止损)的频率,跟拉信号的频率是分开的两件事:
# 这是查币安自己的 API(合法授权的官方接口,不是爬第三方网站),没有"请求太频繁"的顾虑,
# 而且 YBRadar 扫出来的本来就是行情波动很快的币种,3 分钟才查一次止盈止损太慢,
# 默认 5 秒查一次
POSITION_MONITOR_INTERVAL_SECONDS=5

# 只接这个交易所发出的信号(YBRadar 同时扫 binance/okx,但目前只对接了 binance 执行器)
TRADE_EXCHANGE=binance

# ==== 运行模式 ====
# true = 纯模拟(不需要下面的 API Key,用真实行情价格在内存里模拟开平仓,用来先验证策略逻辑)
# false = 真实下单(测试网或实盘取决于 BINANCE_TESTNET)
DRY_RUN=true

# ==== 币安合约 API ====
BINANCE_API_KEY=
BINANCE_API_SECRET=
# true = 币安 USDⓈ-M 合约测试网 (testnet.binancefuture.com,假资金,强烈建议先用这个)
# false = 实盘 (fapi.binance.com,真实资金,务必先在测试网跑通再改成 false)
BINANCE_TESTNET=true
# 美股/大宗商品代币化合约(NVDA、TSLA、XAU 这类,contractType=TRADIFI_PERPETUAL)默认不交易——
# 这类品种需要先在币安网页/APP 上手动签一份 TradFi-Perps 协议,API 层面绕不过去(-4411);
# 而且这套策略的信号打分逻辑是针对加密货币调的,美股品种的持仓量/资金费率行为模式不一样,
# 信号是否还准没有验证过,交易时段也跟随美股(不是 24 小时),务必先小范围观察再改成 true
ALLOW_TRADIFI_PERPETUALS=false

# ==== 仓位与风控参数 ====
# 每笔保证金 = 账户可用余额(USDT) × 这个百分比(小数,0.05 = 5%),不是固定金额 ——
# 余额涨了仓位跟着涨,余额跌了仓位跟着缩,名义仓位 = 这笔保证金 × LEVERAGE。
# 每次开仓前都会重新查一次余额,不是启动时查一次就固定住。
POSITION_SIZE_PCT=0.05
# 只有 DRY_RUN=true 时才会用到:模拟账户没有真实余额,用这个固定值当参考余额
# 来算 POSITION_SIZE_PCT,不会随模拟盈亏滚动
DRY_RUN_BALANCE_USDT=5000
LEVERAGE=10
# 止盈/止损百分比(小数,0.02 = 2%),按币本位涨跌幅计算(entry_price 直接乘百分比),
# 不受杠杆影响 —— 10 倍杠杆下 2% 的价格波动对应约 20% 的保证金收益,但这里的阈值本身
# 始终是"币价格"变动的百分比,不是杠杆后的收益率。
# 止盈止损设成一样(盈亏比 1:1),胜率过 50% 就能赚;等跑出真实胜率数据后再按实际
# 情况调整比例,而不是先凭感觉定一个悬殊的盈亏比。
# 没有"亏损也强平"的超时逻辑:"舔一口就跑"指的是拿到正确收益就走,不是拿够时间就走,
# 没到止盈/止损前一直持有,亏损或持平的仓位不会因为拿久了就被强平
TAKE_PROFIT_PCT=0.02
STOP_LOSS_PCT=0.02

# ==== ATR 动态止损(可选,默认关闭) ====
# 关闭时(默认)止损空间就是上面固定的 STOP_LOSS_PCT,所有品种一刀切。打开之后,
# 开仓那一刻会拉最近的K线算 ATR(平均真实波幅),把止损空间换算成"这个品种最近
# 实际波动有多大"而不是固定百分比——波动小的品种止损收紧,波动大的品种止损放宽。
# 换算出来的百分比会被夹在 [ATR_MIN_STOP_PCT, STOP_LOSS_PCT] 之间:下限避免波动率
# 异常低时止损贴得太近(随便一个噪音就触发),上限还是原来的 STOP_LOSS_PCT,避免
# 波动率异常高的品种算出一个大到离谱的止损空间。查不到K线数据就直接退回固定百分比。
ATR_STOP_LOSS_ENABLED=false
# ATR 用几根K线算(常见默认14根)
ATR_PERIOD=14
# K线的时间粒度,币安支持 1m/3m/5m/15m/1h 等,策略是快进快出的,用短周期的K线更合适
ATR_INTERVAL=5m
# ATR 乘这个系数作为止损空间。1.5倍左右适合短线快进快出,想要更大缓冲空间可以调高
ATR_MULTIPLIER=1.5
# 止损空间的下限(小数,0.005 = 0.5%),不能比 STOP_LOSS_PCT 还大
ATR_MIN_STOP_PCT=0.005

# 持仓超过这个秒数,只要当前有任何盈利(哪怕没到止盈线)就平仓锁定收益,原因记为
# "超时锁盈"。持仓太久说明预期的快速突破大概率已经落空,继续拖着只是在赌反转不会
# 发生;只在有盈利时触发,亏损/持平的仓位完全不受这条影响,跟上面"没有超时强平"
# 的原则不冲突——这条只锁盈,不止损
PROFIT_LOCK_AFTER_SECONDS=600
# 超过上面那个时间后,还需要浮盈超过这个百分比(小数,0.003 = 0.3%)才会真的触发锁盈。
# 市价单平仓有真实的手续费+滑点成本,如果浮盈太薄(比如只有0.05%),锁盈这个动作
# 执行完反而会变成亏损——这个门槛就是防止"为了锁盈反而亏钱"。经验值大概是覆盖
# 一次往返手续费(约0.1%)再留一点滑点余量,不要设成 0
PROFIT_LOCK_MIN_PCT=0.003

# ==== 阶梯止盈(分批止盈,让盈利的仓位有机会吃到更大的行情) ====
# 关闭时(默认)完全是老逻辑:碰到止盈线一次性全平。打开之后碰到止盈线只平掉一部分,
# 剩下的止损上移到保本附近继续持有,每再往有利方向走一个 TAKE_PROFIT_PCT 就再平掉
# 剩余仓位的一半,直到封顶(LADDER_MAX_LEVELS 档),剩下的尾巴交给保本止损/超时锁盈处理。
# 比如 TAKE_PROFIT_PCT=0.02、第1档70%、之后每档50%、封顶6档:
#   entry+2%平70%(剩30%,止损上移保本) -> +4%再平50%(剩15%) -> +6%再平50%(剩7.5%)
#   -> +8%(剩3.75%) -> +10%(剩1.875%) -> +12%(剩0.9375%,封顶,不再继续加档)
LADDER_TAKE_PROFIT_ENABLED=false
# 第1档平仓比例(小数,0.70 = 70%)
LADDER_FIRST_CLOSE_PCT=0.70
# 第2档及以后,每档平掉"当前剩余仓位"的这个比例(小数,0.50 = 50%)
LADDER_STEP_CLOSE_PCT=0.50
# 最多加到第几档,超过这个档位就不再继续分批,剩下的仓位交给保本止损/超时锁盈处理
LADDER_MAX_LEVELS=6
# 第1档触发后,止损线上移到"开仓价 × (1 + 这个百分比)",不是精确的开仓价——留一点
# 缓冲覆盖平仓时的真实手续费+滑点,不然"保本"执行完可能变成小亏
LADDER_BREAKEVEN_BUFFER_PCT=0.001

# 同一时间最多几个仓位
MAX_CONCURRENT_POSITIONS=3
# 平仓后同一币种多久内不再重复进场(秒)
SYMBOL_COOLDOWN_SECONDS=1800
# 当日累计亏损达到 账户余额×这个百分比 就停止开新仓(小数,0.15 = 15%),只保留已有
# 仓位的止盈止损逻辑。跟 POSITION_SIZE_PCT 一样按余额百分比算,不是写死的美元数——
# 不然账户资金一变(比如从几千U的测试网换成几百U的实盘),同一个数字要么形同虚设
# (熔断线接近甚至超过总资金)要么过度保守
MAX_DAILY_LOSS_PCT=0.15

# ==== 监控面板(独立进程 src/dashboard.py,不影响交易主程序) ====
# 面板监听的端口,需要在服务器防火墙里单独放行(bootstrap.sh 会自动处理)
DASHBOARD_PORT=8080
# 面板用 HTTP Basic Auth 做访问控制,务必改成自己的账号密码,不要用示例值。
# 注意 Basic Auth 是明文传输(没配 HTTPS 的话),不要用你其他地方也在用的密码
DASHBOARD_USERNAME=换成你自己的用户名
DASHBOARD_PASSWORD=换成一个强密码,不要用示例值
